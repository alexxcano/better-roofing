# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth v5
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe (https://dashboard.stripe.com/)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create manually in Stripe dashboard)
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# Stripe public key (used client-side for redirects)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Google Maps (https://console.cloud.google.com/)
# Server-side only — used for Places autocomplete proxy + Solar API. Never exposed to the browser.
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Mapbox (https://account.mapbox.com/) — satellite imagery in widget + dashboard
# Restrict this token to your domain in Mapbox dashboard
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1..."

# App URL (used for Stripe redirects and widget iframe src)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (https://resend.com) — for lead email notifications
RESEND_API_KEY="re_..."

# OpenAI — for AI follow-up email drafts + weekly reports (Pro feature)
OPENAI_API_KEY="sk-..."

# Cron secret — protects /api/cron/* endpoints (Vercel sets this automatically in production)
CRON_SECRET="generate-a-random-secret-here"
